# ObsidianHomeOrchestrator — Environment Variables
# Copy to .env and fill in values. NEVER commit .env to git.

# ── Obsidian Vault ────────────────────────────────────────────
# Only needed for local Python scripts (not n8n workflows)
OBSIDIAN_VAULT_PATH=/path/to/your/Homelab

# ── MinIO S3 (Primary storage for n8n workflows) ──────────────
MINIO_ENDPOINT=http://192.168.1.240:9000
MINIO_ACCESS_KEY=                          # Claude_Cowork service account access key
MINIO_SECRET_KEY=                          # Claude_Cowork service account secret key
MINIO_BUCKET=obsidian-vault
MINIO_VAULT_PREFIX=Homelab                 # Prefix inside bucket for vault files (no trailing slash)

# ── LLM API Keys (Free Tier) ─────────────────────────────────
# Primary: Groq (Llama 3.3 70B) — Get free key at https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx
# Fallback: Google Gemini 2.0 Flash — Get free key at https://aistudio.google.com
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Claude / Anthropic ────────────────────────────────────────
ANTHROPIC_API_KEY=                         # Required for AI-enhanced brain dump processing

# ── n8n ───────────────────────────────────────────────────────
N8N_HOST=http://192.168.1.121:5678
N8N_API_KEY=                              # Generate at n8n → Settings → API → Create API Key
N8N_USER=admin
N8N_PASSWORD=
N8N_ENCRYPTION_KEY=

# ── Email (SMTP — used by brain dump digest + weekly digest) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=aaron.deyoung@gmail.com
SMTP_PASS=                                 # Gmail App Password (NOT account password)
                                           # Google Account → Security → 2FA → App Passwords

# ── Notifications (used by overdue task alert) ────────────────
NOTIFICATION_WEBHOOK_URL=                  # Optional: Slack/ntfy/Pushover webhook
                                           # Leave blank to use email only

# ── PostgreSQL (MiniPC Docker) ────────────────────────────────
POSTGRES_USER=homelab
POSTGRES_PASSWORD=
POSTGRES_DB=homelab
