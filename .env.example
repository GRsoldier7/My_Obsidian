# ObsidianHomeOrchestrator — Environment Variables
# Copy to .env and fill in values. NEVER commit .env to git.
#
# Legend:
#   [setup-n8n.sh]        — used by scripts/setup-n8n.sh
#   [process_brain_dump]   — used by tools/process_brain_dump.py
#   [docker-compose]       — used by external docker-compose (not in this repo)

# ── Obsidian Vault ────────────────────────────────────────────
# [process_brain_dump] Local vault path for Python scripts (fallback for --vault-path)
OBSIDIAN_VAULT_PATH=/path/to/your/Homelab

# ── MinIO S3 (Primary storage for n8n workflows) ──────────────
# [setup-n8n.sh] Used to create n8n credential and configure S3 endpoint
MINIO_ENDPOINT=http://192.168.1.240:9000
MINIO_ACCESS_KEY=                          # Claude_Cowork service account access key
MINIO_SECRET_KEY=                          # Claude_Cowork service account secret key
MINIO_BUCKET=obsidian-vault                # Reference only — hardcoded in workflow templates
MINIO_VAULT_PREFIX=Homelab                 # Reference only — hardcoded in workflow JS code nodes

# ── LLM API Key ───────────────────────────────────────────────
# OpenRouter — unified LLM gateway, free tier available at https://openrouter.ai
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Claude / Anthropic ────────────────────────────────────────
# [process_brain_dump] Auto-read by anthropic SDK
ANTHROPIC_API_KEY=

# ── OpenRouter (AI for n8n workflows) ────────────────────────
# [setup-n8n.sh] Used to create n8n httpHeaderAuth credential for Llama 3.3 70B
OPENROUTER_API_KEY=                       # Free tier at https://openrouter.ai

# ── n8n ───────────────────────────────────────────────────────
# [setup-n8n.sh] n8n API connection
N8N_HOST=http://192.168.1.121:5678
N8N_API_KEY=                              # Generate at n8n > Settings > API > Create API Key

# ── Email (SMTP) ─────────────────────────────────────────────
# [setup-n8n.sh] Used to create n8n SMTP credential and set email recipients
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=aaron.deyoung@gmail.com
SMTP_PASS=                                 # Gmail App Password (NOT account password)
                                           # Google Account > Security > 2FA > App Passwords
NOTIFICATION_EMAIL=aaron.deyoung@gmail.com # To/from for workflow emails (defaults to SMTP_USER)

# ── Notifications ────────────────────────────────────────────
# [not yet wired] Optional webhook for Slack/ntfy/Pushover
NOTIFICATION_WEBHOOK_URL=

# ── PostgreSQL (if using docker-compose externally) ──────────
# [docker-compose] Not consumed by anything in this repo
POSTGRES_USER=homelab
POSTGRES_PASSWORD=
POSTGRES_DB=homelab
