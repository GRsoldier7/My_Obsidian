# ObsidianHomeOrchestrator — Environment Variables
# Copy to .env and fill in values. NEVER commit .env to git.
#
# Legend:
#   [process_brain_dump]   — used by tools/process_brain_dump.py
#   [health_check]         — used by scripts/health_check.py
#   [e2e_test]             — used by scripts/e2e_test.py
#   [setup-n8n.sh]         — used by scripts/setup-n8n.sh

# ── Obsidian Vault ────────────────────────────────────────────
# [process_brain_dump] Local vault path for Python scripts
OBSIDIAN_VAULT_PATH=/path/to/your/vault

# ── MinIO S3 (Primary storage) ───────────────────────────────
# [process_brain_dump, health_check, e2e_test]
MINIO_ENDPOINT=http://192.168.1.240:9000
MINIO_ACCESS_KEY=                          # MinIO service account access key
MINIO_SECRET_KEY=                          # MinIO service account secret key
MINIO_BUCKET=obsidian-vault
MINIO_VAULT_PREFIX=                        # EMPTY — vault files at bucket root (no Homelab/ prefix)

# ── OpenRouter (AI extraction) ───────────────────────────────
# [process_brain_dump] Free tier models for task/article extraction
# Models used: google/gemma-3-4b-it:free (primary), llama-3.3-70b:free (fallback)
OPENROUTER_API_KEY=                        # Get free key at https://openrouter.ai

# ── n8n ───────────────────────────────────────────────────────
# [setup-n8n.sh] n8n API for workflow deployment
N8N_HOST=http://192.168.1.121:5678
N8N_API_KEY=                               # n8n > Settings > API > Create API Key

# ── Email (SMTP) ─────────────────────────────────────────────
# [setup-n8n.sh] Gmail SMTP for workflow notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=                                 # Gmail App Password (NOT account password)
NOTIFICATION_EMAIL=your-email@gmail.com

# ── PostgreSQL (external docker-compose) ─────────────────────
POSTGRES_USER=homelab
POSTGRES_PASSWORD=
POSTGRES_DB=homelab
